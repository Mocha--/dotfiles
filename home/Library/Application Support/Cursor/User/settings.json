    "textMateRules": [
      {
        "scope": [
          "keyword.control",
          "constant",
        ],
        "settings": {
          "fontStyle": "italic"
        }
      }
    ]
  },
  "emmet.excludeLanguages": [
    "markdown",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
