  "custom-ui-style.electron": {
    "frame": false,
    "transparent": true,
    "opacity": 0.96 // Range: 0-1 (To go fully transparent, set it to 0)
  },
  "breadcrumbs.enabled": false,
  "breadcrumbs.filePath": "last",
  "color-highlight.matchWords": false,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.acceptSuggestionOnEnter": "on",
  "editor.accessibilitySupport": "off",
  "editor.autoClosingDelete": "always",
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.colorDecorators": false,
  "editor.cursorBlinking": "phase",
  "editor.fontFamily": "'Maple Mono NF CN', 'Fira Code', 'Roboto Mono', 'Droid Sans Mono', 'Courier New', monospace, 'Droid Sans Fallback'",
  "editor.fontLigatures": true,
  "editor.fontSize": 16,
  "editor.fontWeight": "normal",
  "editor.guides.indentation": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.inlayHints.enabled": "onUnlessPressed",
  "editor.inlayHints.fontSize": 14,
  "editor.inlayHints.padding": true,
  "editor.letterSpacing": 0.5,
  "editor.lineHeight": 28,
  "editor.linkedEditing": true,
  "editor.matchBrackets": "never",
  "editor.minimap.enabled": true,
  "editor.minimap.scale": 2,
  "editor.minimap.showSlider": "always",
  "editor.minimap.size": "proportional",
  "editor.parameterHints.enabled": false,
  "editor.quickSuggestions": {
    "comments": false,
