  "vim.easymotionMarkerForegroundColorOneChar": "#6c938a",
  "vim.hlsearch": true,
  "vim.insertModeKeyBindingsNonRecursive": [
    {
      "after": [
        "<Esc>"
      ],
      "before": [
        "j",
        "k"
      ]
    }
  ],
  "vim.leader": "\\",
  "vim.mouseSelectionGoesIntoVisualMode": false,
  "vim.normalModeKeyBindings": [
    {
      "after": [
        "1",
        "0",
        "j"
      ],
      "before": [
        "J"
      ]
    },
    {
      "after": [
        "1",
        "0",
        "k"
      ],
      "before": [
        "K"
      ]
    },
    {
      "after": [
        "3",
        "w"
      ],
      "before": [
        "W"
      ]
    },
    {
      "after": [
        "3",
        "e"
      ],
      "before": [
        "E",
      ]
    },
    {
      "after": [
        "z",
        "c"
      ],
      "before": [
        "z",
        "a"
      ]
    },
    {
      "after": [
        "$",
        "s"
      ],
      "before": [
        "M"
      ]
    },
    {
      "before": [
        "g",
        "r"
      ],
      "commands": [
        "references-view.findReferences"
      ]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "after": [],
      "before": [
        "L"
      ],
      "commands": [
        {
          "command": "workbench.action.nextEditor"
        }
      ]
    },
    {
      "after": [],
      "before": [
        "H"
      ],
      "commands": [
        {
          "command": "workbench.action.previousEditor"
        }
      ]
    },
    {
      "after": [],
      "before": [
        "C-w"
      ],
      "commands": [
        {
          "command": "workbench.action.closeActiveEditor"
        }
      ]
    },
    {
      "after": [
        "<leader>",
        "<leader>",
        "2",
        "s"
      ],
      "before": [
        "s"
      ]
    },
    {
      "after": [
        "3",
        "w"
      ],
      "before": [
        "W"
      ]
    },
    {
      "after": [
        "3",
        "e"
      ],
      "before": [
        "E",
      ]
    },
  ],
  "vim.searchHighlightColor": "#7f4a5a",
  "vim.useSystemClipboard": true,
  "vim.visualModeKeyBindings": [
    {
      "after": [
        "1",
        "0",
        "j"
      ],
      "before": [
        "J"
      ]
    },
    {
      "after": [
        "1",
        "0",
        "k"
      ],
      "before": [
        "K"
      ]
    },
  ],
