{
  "autoDreamEnabled": false,
  "autoMemoryEnabled": true,
  "enabledPlugins": {
    "otter-tools@otter-marketplace": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_SCROLL_SPEED": "8",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/notification-hook.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "permission_prompt|elicitation_dialog"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "/usr/local/bin/otter agent-hook --agent claude-code --hook-event PostToolUse",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/usr/local/bin/otter agent-hook --agent claude-code --hook-event PreToolUse",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "/usr/local/bin/otter agent-hook --agent claude-code --hook-event SessionStart",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/stop-hook.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch(domain:*)",
      "WebSearch",
      "mcp__*"
    ],
    "defaultMode": "bypassPermissions"
  },
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "type": "command"
  }
}