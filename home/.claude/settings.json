{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_SCROLL_SPEED": "8",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_NOTIFY_WEBHOOK_URL": "https://hooks.slack.com/triggers/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",
    "CLAUDE_NOTIFY_NOTIFICATION_PAYLOAD": "{\"origin\": \"🍎 Macbook\", \"message\": \"🚨 Waiting for input\"}",
    "CLAUDE_NOTIFY_STOP_PAYLOAD": "{\"origin\": \"🍎 Macbook\", \"message\": \"✅ Complete\"}"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch(domain:*)",
      "WebSearch",
      "mcp__*"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "oh-my-claudecode@omc": true,
    "claude-code-notify-plugin@mocha-plugins": true
  },
  "extraKnownMarketplaces": {
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    },
    "mocha-plugins": {
      "source": {
        "source": "github",
        "repo": "Mocha--/claude-code-notify-plugin"
      },
      "autoUpdate": true
    }
  },
  "autoMemoryEnabled": true,
  "autoDreamEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim"
}
